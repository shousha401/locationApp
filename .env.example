# Copy to .env and adjust. .env is gitignored — never commit secrets.

# Port the app listens on.
PORT=3010

# Only show locations starting with this prefix (blank = every location).
# The filter is pushed to Swarmbox, so GT-only also means a much smaller pull.
LOCATION_PREFIX=GT

# How often to pull the full inventory snapshot from Swarmbox (ms). Default 5 min.
# One pull covers every location, so this is the ONLY Swarmbox load the app makes.
SNAPSHOT_REFRESH_MS=300000

# Swarmbox PostgREST. The snapshot is ~250k rows / ~20s, so the timeout is generous.
SWARMBOX_BASE_URL=https://jdfood.swarmbox.com:443/pg-api
SWARMBOX_TIMEOUT_MS=120000
SWARMBOX_CONCURRENCY=2

# Session lifetime (ms). Default 12h sliding.
SESSION_TTL_MS=43200000
