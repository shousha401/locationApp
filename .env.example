# Copy to .env and adjust. .env is gitignored — never commit secrets.

# Port the app listens on. 3005 is the next free port on CMP-APP02
# (3002 clayTool, 3003 formulation, 3004 valueTool, 3010 CMP Maintenance).
PORT=3005

# Only show locations starting with this prefix. The filter is pushed to
# Swarmbox, so GT-only also means a much smaller pull (~1.7k rows vs ~250k).
# Serving EVERY location requires the explicit token * (or ALL) — blank or
# unset falls back to GT so a dangling line here can't switch on the full pull.
LOCATION_PREFIX=GT

# How often to pull the full inventory snapshot from Swarmbox (ms). Default 15 min —
# pallets sit for hours-to-days, so faster refreshes just re-download identical data.
# One pull covers every location, so this is the ONLY Swarmbox load the app makes.
SNAPSHOT_REFRESH_MS=900000

# Optional: API key for the requests channel ONLY (X-Api-Key header on /api/requests*).
# Lets the build side read and answer the queue from scripts without a browser session.
# The key works nowhere else — inventory, notes and users still require a login.
# Leave blank to disable the lane entirely.
API_KEY=

# Swarmbox PostgREST. The snapshot is ~250k rows / ~20s, so the timeout is generous.
SWARMBOX_BASE_URL=https://jdfood.swarmbox.com:443/pg-api
SWARMBOX_TIMEOUT_MS=120000
SWARMBOX_CONCURRENCY=2

# Session lifetime (ms). Default 12h sliding.
SESSION_TTL_MS=43200000
